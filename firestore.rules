rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidJournalEntry(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidUserSettings(data) {
      return data.pin is string && data.pin.matches('^[0-9]{4}$') &&
             data.userId == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /journal/{entryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJournalEntry(incoming());
        allow update: if isOwner(userId) && isValidJournalEntry(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'mood']);
        allow delete: if isOwner(userId);
      }

      match /settings/profile {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserSettings(incoming());
        allow update: if isOwner(userId) && isValidUserSettings(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['pin']);
      }
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      // Only admins should write, but for simplicity we'll assume global read.
    }
  }
}
